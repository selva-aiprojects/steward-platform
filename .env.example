# Core app settings
APP_ENV=DEV
EXECUTION_MODE=PAPER_TRADING
ENABLE_LIVE_TRADING=false
GLOBAL_KILL_SWITCH=false

# Security
# Use a long random value in all non-local environments.
SECRET_KEY=replace-with-64-char-random-secret
ALLOW_DEMO_AUTH=false
ALLOW_DEV_USER_FALLBACK=false
ALLOW_HEADER_IDENTITY=true

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
DATABASE_URL=sqlite:///./stocksteward.db

# Broker/Data/AI keys
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_ACCESS_TOKEN=
TRUEDATA_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
HUGGINGFACE_API_KEY=

